{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm-run-dev",
            "type": "npm",
            "script": "dev",
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*VITE.*",
                    "endsPattern": ".*ready in.*"
                },
                "pattern": {
                    "regexp": "^$"
                }
            }
        }
    ]
}
